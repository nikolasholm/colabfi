<div id="networkModal" class="fixed inset-0 bg-black/60 backdrop-blur-lg hidden flex items-center justify-center z-[999]">
  <div class="bg-black/0 p-8 rounded-lg max-w-4xl w-full mx-4 z-[9999] relative">
    <button id="closeNetworkModal" class="absolute top-0 right-0 text-gray-400 hover:text-gray-200">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
    <h2 class="mb-3">
       We are searching for co:founders and co:llaborators.
    </h2>
    <p>  Sign up to the network to hear more about our missions.</p>


    <form data-form="2eedd36f-dcb7-4aa0-bc71-c1b03d510e8c" class="mt-8">
        <fieldset data-id="95178f8b" data-required="true" class="gap-x-3 flex flex-wrap mb-3">
          <legend class="mb-2">I am</legend>
          <label><input type="radio" name="95178f8b" value="Designer" /> Designer</label>
          <label><input type="radio" name="95178f8b" value="Developer" /> Developer</label>
          <label><input type="radio" name="95178f8b" value="Operator" /> Operator</label>
          <label><input type="radio" name="95178f8b" value="Investor" /> Investor</label>
          <label><input type="radio" name="95178f8b" value="Other" /> Other</label>
        </fieldset>
        <input type="email" data-id="dcf2b8ca" data-label="Email" required placeholder="Email" aria-label="Email" class="w-full text-xl placeholder:text-zinc-400 border-b-2 mb-3 py-4 text-white bg-transparent focus:outline-none" />
        <textarea data-id="2fa61a84" data-label="Message" placeholder="Message" aria-label="Message" class="w-full text-xl placeholder:text-zinc-400 border-b-2 mb-3 py-4 text-white bg-transparent focus:outline-none"></textarea>
        <button type="submit" class="w-full bg-white hover:bg-zinc-200 text-black font-medium py-4 rounded mt-6">Submit</button>
    </form>
    <script is:inline src="https://reforms.dev/embed-unstyled.js"></script>


  </div>
</div>

<script>
  const modal = document.getElementById('networkModal');
  const closeBtn = document.getElementById('closeNetworkModal');
  const form = modal?.querySelector('form[data-form]');
  let submitted = false;

  window.openNetworkModal = () => {
    modal?.classList.remove('hidden');
  };

  closeBtn?.addEventListener('click', () => {
    modal?.classList.add('hidden');
  });

  // Close modal when clicking outside — but not once the form has been submitted,
  // so the success message stays visible until the user explicitly closes it.
  modal?.addEventListener('click', (e) => {
    if (e.target === modal && !submitted) {
      modal.classList.add('hidden');
    }
  });

  // Belt-and-braces: prevent native form submission (which would navigate/reload
  // the page and hide the modal) even if the reforms.dev script hasn't attached yet.
  // reforms.dev's own submit listener still runs — preventDefault in one listener
  // doesn't stop others on the same event.
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    submitted = true;
  });
</script> 